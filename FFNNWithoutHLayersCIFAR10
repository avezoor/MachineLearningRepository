    "    print(f\"Mulai pelatihan dengan optimizer: {optimizerName}\")\n",
    "\n",
    "    model, history, bestEpoch, bestValAccuracy, totalTime, logLines = trainOneExperiment(\n",
    "        config,\n",
    "        xTrain,\n",
    "        yTrainOneHot,\n",
    "        yTrain,\n",
    "        xVal,\n",
    "        yValOneHot,\n",
    "        yVal,\n",
    "    )\n",
    "\n",
    "    testLoss, testAccuracy, _ = evaluateModel(\n",
    "        model,\n",
    "        xTest,\n",
    "        yTestOneHot,\n",
    "        yTest,\n",
    "        weightDecay=config['lossWeightDecay'],\n",
    "    )\n",
    "\n",
    "    optimizerFileName = optimizerName.lower().replace(' ', '_').replace('-', '_') + '.txt'\n",
    "    optimizerLogPath = logDir / optimizerFileName\n",
    "    logLines.append('')\n",
    "    logLines.append(f\"Epoch terbaik           : {bestEpoch}\")\n",
    "    logLines.append(f\"Akurasi validasi terbaik: {bestValAccuracy:.4f}\")\n",
    "    logLines.append(f\"Loss data uji           : {testLoss:.4f}\")\n",
    "    logLines.append(f\"Akurasi data uji        : {testAccuracy:.4f}\")\n",
