    "def evaluateModel(model, xData, yOneHot, yLabels, weightDecay=0.0):\n",
    "    _, probabilities = model.forward(xData)\n",
    "    loss = crossEntropyLoss(probabilities, yOneHot) + 0.5 * weightDecay * np.sum(model.w * model.w)\n",
    "    predictions = np.argmax(probabilities, axis=1)\n",
    "    accuracy = calculateAccuracy(yLabels, predictions)\n",
    "    return float(loss), float(accuracy), predictions\n"
   ]
