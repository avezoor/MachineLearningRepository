    "def resolveInputDir(candidateRoots):\n",
    "    for rootDir in candidateRoots:\n",
    "        if not rootDir.exists():\n",
    "            continue\n",
    "\n",
    "        directCandidates = [\n",
    "            rootDir,\n",
    "            rootDir / 'cifar-10-batches-py',\n",
    "            rootDir / 'cifar10-python',\n",
    "            rootDir / 'cifar10-python' / 'cifar-10-batches-py',\n",
    "        ]\n",
    "        for candidatePath in directCandidates:\n",
    "            if (candidatePath / 'batches.meta').exists():\n",
    "                return candidatePath\n",
    "\n",
    "        for pattern in ('**/batches.meta', '**/cifar-10-python.tar.gz', '**/cifar-10-batches-py.tar.gz'):\n",
    "            matches = sorted(rootDir.glob(pattern))\n",
    "            if matches:\n",
    "                return matches[0].parent\n",
    "\n",
    "    return None\n",
    "\n",
    "inputDir = resolveInputDir(inputDirCandidates)\n",
