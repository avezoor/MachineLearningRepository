    "def computeConfusionMatrix(trueLabels, predictedLabels, numClasses):\n",
    "    matrix = np.zeros((numClasses, numClasses), dtype=np.int64)\n",
    "    for trueLabel, predictedLabel in zip(trueLabels, predictedLabels):\n",
    "        matrix[trueLabel, predictedLabel] += 1\n",
    "    return matrix\n",
    "\n",
    "\n",
    "bestOptimizerName = summaryTable.iloc[0]['Optimizer']\n",
    "bestModel = trainedModels[bestOptimizerName]\n",
    "bestTestPredictions = bestModel.predictClass(xTest)\n",
    "confusionMatrix = computeConfusionMatrix(yTest, bestTestPredictions, numClasses)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "image = ax.imshow(confusionMatrix, cmap='Blues')\n",
    "ax.set_title(f\"Matriks kebingungan - {bestOptimizerName}\")\n",
    "ax.set_xlabel('Label prediksi')\n",
    "ax.set_ylabel('Label asli')\n",
    "ax.set_xticks(range(numClasses))\n",
    "ax.set_xticklabels(classNames, rotation=45, ha='right')\n",
    "ax.set_yticks(range(numClasses))\n",
    "ax.set_yticklabels(classNames)\n",
    "plt.colorbar(image, ax=ax)\n",
