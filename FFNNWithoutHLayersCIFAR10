":"## Definisikan model FFNN tanpa hidden layer","metadata":{}},{"cell_type":"code","source":"class FFNNNoHidden(nn.Module):\n    def __init__(self, inputSize=3072, outputSize=10):\n        super().__init__()\n        self.outputLayer = nn.Linear(inputSize, outputSize)\n\n    def forward(self, inputData):\n        return self.outputLayer(inputData)\n\n\nmodel = FFNNNoHidden().to(device)\nprint(model)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-12T08:27:44.811739Z","iopub.execute_input":"2026-03-12T08:27:44.812048Z","iopub.status.idle":"2026-03-12T08:27:44.855204Z","shell.execute_reply.started":"2026-03-12T08:27:44.812018Z","shell.execute_reply":"2026-03-12T08:27:44.854278Z"}},"outputs":[{"name":"stdout","text":"FFNNNoHidden(\n  (outputLayer): Linear(in_features=3072, out_features=10, bias=True)\n)\n","output_type":"stream"}],"execution_count":20},{"cell_type":"markdown","source":"## Buat fungsi evaluasi","metadata":{}},{"cell_type":"code","source":"def evaluateModel(model, dataLoader, lossFunction):\n    model.eval()\n\n    totalLoss = 0.0\n    predictionList = []\n    targetList = []\n\n    with torch.no_grad():\n        for featureBatch, targetBatch in dataLoader:\n            featureBatch = featureBatch.to(device)\n            targetBatch = targetBatch.to(device)\n\n            outputLogits = model(featureBatch)\n            lossValue = lossFunction(outputLogits, targetBatch)\n\n            totalLoss += lossValue.item() * featureBatch.size(0)\n\n            predictedClass = torch.argmax(outputLogits, dim=1)\n            predictionList.extend(predictedClass.cpu().numpy())\n            targetList.extend(targetBatch.cpu().numpy())\n\n    averageLoss = totalLoss / len(dataLoader.dataset)\n    accuracyValue = accuracy_score(targetList, predictionList)\n\n    return averageLoss, accuracyValue, np.array(predictionList), np.array(targetList)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-12T08:27:44.856419Z","iopub.execute_input":"2026-03-12T08:27:44.856666Z","iopub.status.idle":"2026-03-12T08:27:44.864311Z","shell.execute_reply.started":"2026-03-12T08:27:44.856638Z","shell.execute_reply":"2026-03-12T08:27:44.863228Z"}},"outputs":[],"execution_count":21},{"cell_type":"markdown","source":"## Buat fungsi training","metadata":{}},{"cell_type":"code","source":"def trainOneModel(optimizerName, optimizerObject, model, trainLoader, valLoader, epochCount=15):\n    lossFunction = nn.CrossEntropyLoss()\n\n    historyData = {\n        \"epoch\": [],\n        \"trainLoss\": [],\n        \"trainAccuracy\": [],\n        \"valLoss\": [],\n        \"valAccuracy\": []\n    }\n\n    for epochIndex in range(1, epochCount + 1):\n        model.train()\n\n        totalTrainLoss = 0.0\n        trainPredictionList = []\n        trainTargetList = []\n\n        for featureBatch, targetBatch in trainLoader:\n            featureBatch = featureBatch.to(device)\n            targetBatch = targetBatch.to(device)\n\n            optimizerObject.zero_grad()\n\n            outputLogits = model(featureBatch)\n            lossValue = lossFunction(outputLogits, targetBatch)\n\n            lossValue.backward()\n            optimizerObject.step()\n\n            totalTrainLoss += lossValue.item() * featureBatch.size(0)\n\n            predictedClass = torch.argmax(outputLogits, dim=1)\n            trainPredictionList.extend(predictedClass.detach().cpu().numpy())\n            trainTargetList.extend(targetBatch.detach().cpu().numpy())\n\n        averageTrainLoss = totalTrainLoss / len(trainLoader.dataset)\n        trainAccuracy = accuracy_score(trainTargetList, trainPredictionList)\n\n        valLoss, valAccuracy, _, _ = evaluateModel(model, valLoader, lossFunction)\n\n        historyData[\"epoch\"].append(epochIndex)\n        historyData[\"trainLoss\"].append(averageTrainLoss)\n        historyData[\"trainAccuracy\"].append(trainAccuracy)\n        historyData[\"valLoss\"].append(valLoss)\n        historyData[\"valAccuracy\"].append(valAccuracy)\n\n        print(\n            f\"[{optimizerName}] Epoch {epochIndex:02d}/{epochCount} | \"\n            f\"Train Loss: {averageTrainLoss:.4f} | \"\n            f\"Train Acc: {trainAccuracy:.4f} | \"\n            f\"Val Loss: {valLoss:.4f} | \"\n            f\"Val Acc: {valAccuracy:.4f}\"\n        )\n\n    return pd.DataFrame(historyData)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-12T08:27:44.865613Z","iopub.execute_input":"2026-03-12T08:27:44.865867Z","iopub.status.idle":"2026-03-12T08:27:44.899354Z","shell.execute_reply.started":"2026-03-12T08:27:44.865847Z","shell.execute_reply":"2026-03-12T08:27:44.897991Z"}},"outputs":[],"execution_count":22},{"cell_type":"markdown","source":"## Buat factory optimizer","metadata":{}},{"cell_type":"code","source":"def createOptimizer(optimizerName, model):\n    optimizerName = optimizerName.lower()\n\n    if optimizerName == \"sgd\":\n        return torch.optim.SGD(model.parameters(), lr=0.05)\n\n    if optimizerName == \"momentum\":\n        return torch.optim.SGD(model.parameters(), lr=0.05, momentum=0.9)\n\n    if optimizerName == \"nag\":\n        return torch.optim.SGD(model.parameters(), lr=0.05, momentum=0.9, nesterov=True)\n\n    if optimizerName == \"rmsprop\":\n        return torch.optim.RMSprop(model.parameters(), lr=0.001)\n\n    if optimizerName == \"adam\":\n        return torch.optim.Adam(model.parameters(), lr=0.001)\n\n    if optimizerName == \"adamw\":\n        return torch.optim.AdamW(model.parameters(), lr=0.001, weight_decay=1e-4)\n\n    raise ValueError(f\"Optimizer tidak dikenali: {optimizerName}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-03-12T08:27:44.900812Z","iopub.execute_input":"2026-03-12T08:27:44.901358Z","iopub.status.idle":"2026-03-12T08:27:44.930312Z","shell.execute_reply.started":"2026-03-12T08:27:44.901330Z","shell.execute_reply":"2026-03-12T08:27:44.929295Z"}},"outputs":[],"execution_count":23},{"cell_type":"markdown","s