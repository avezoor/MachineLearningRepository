    "def flattenImages(images):\n",
    "    return images.reshape(images.shape[0], -1).astype(np.float32) / 255.0\n",
    "\n",
    "\n",
    "def oneHotEncode(labels, numClasses):\n",
    "    encoded = np.zeros((labels.shape[0], numClasses), dtype=np.float32)\n",
    "    encoded[np.arange(labels.shape[0]), labels] = 1.0\n",
    "    return encoded\n"
   ]
