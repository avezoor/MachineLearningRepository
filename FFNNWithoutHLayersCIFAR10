    "def trainOneExperiment(config, xTrain, yTrainOneHot, yTrain, xVal, yValOneHot, yVal):\n",
    "    model = LinearSoftmaxClassifier(inputDim=inputDim, numClasses=numClasses, seed=randomSeed)\n",
    "    optimizer = config['optimizerFactory']()\n",
    "    batchRng = np.random.default_rng(randomSeed)\n",
    "    history = {\n",
    "        'epoch': [],\n",
    "        'trainLoss': [],\n",
    "        'trainAccuracy': [],\n",
    "        'valLoss': [],\n",
    "        'valAccuracy': [],\n",
    "        'epochTime': [],\n",
    "    }\n",
    "\n",
    "    bestValAccuracy = -np.inf\n",
    "    bestEpoch = -1\n",
    "    bestParameters = None\n",
    "    totalStartTime = time.perf_counter()\n",
    "    logLines = []\n",
    "\n",
    "    for epochIndex in range(1, config['numEpochs'] + 1):\n",
    "        epochStartTime = time.perf_counter()\n",
    "\n",
    "        for xBatch, yBatch in iterateMiniBatches(xTrain, yTrainOneHot, config['batchSize'], batchRng, shuffle=True):\n",
    "            parameters = model.getParameters()\n",
    "\n",
    "            if getattr(optimizer, 'requiresLookAhead', False):\n",
    "                optimizer.beginLookAhead(parameters)\n",
    "                _, gradients, _ = model.computeLossAndGradients(xBatch, yBatch, weightDecay=config['lossWeightDecay'])\n",
    "                optimizer.endLookAhead(parameters)\n",
    "            else:\n",
    "                _, gradients, _ = model.computeLossAndGradients(xBatch, yBatch, weightDecay=config['lossWeightDecay'])\n",
    "\n",
    "            optimizer.step(parameters, gradients)\n",
    "\n",
    "        trainLoss, trainAccuracy, _ = evaluateModel(model, xTrain, yTrainOneHot, yTrain, weightDecay=config['lossWeightDecay'])\n",
    "        valLoss, valAccuracy, _ = evaluateModel(model, xVal, yValOneHot, yVal, weightDecay=config['lossWeightDecay'])\n",
    "        epochTime = time.perf_counter() - epochStartTime\n",
    "\n",
    "        history['epoch'].append(epochIndex)\n",
    "        history['trainLoss'].append(trainLoss)\n",
    "        history['trainAccuracy'].append(trainAccuracy)\n",
    "        history['valLoss'].append(valLoss)\n",
    "        history['valAccuracy'].append(valAccuracy)\n",
    "        history['epochTime'].append(epochTime)\n",
    "\n",
    "        if valAccuracy > bestValAccuracy:\n",
    "            bestValAccuracy = valAccuracy\n",
    "            bestEpoch = epochIndex\n",
    "            bestParameters = {name: value.copy() for name, value in model.getParameters().items()}\n",
    "\n",
    "        epochLogLine = (\n",
    "            f\"[{config['name']}] epoch {epochIndex:02d}/{config['numEpochs']} \"\n",
    "            f\"loss latih={trainLoss:.4f} akurasi latih={trainAccuracy:.4f} \"\n",
    "            f\"loss validasi={valLoss:.4f} akurasi validasi={valAccuracy:.4f} waktu={epochTime:.2f} detik\"\n",
    "        )\n",
    "        logLines.append(epochLogLine)\n",
    "        print(epochLogLine)\n",
    "\n",
    "    if bestParameters is not None:\n",
    "        parameters = model.getParameters()\n",
    "        for name in parameters:\n",
    "            parameters[name][...] = bestParameters[name]\n",
    "\n",
    "    totalTime = time.perf_counter() - totalStartTime\n",
    "    return model, history, bestEpoch, float(bestValAccuracy), float(totalTime), logLines\n"
