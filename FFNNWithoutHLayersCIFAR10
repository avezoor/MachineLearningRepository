    "def loadCifarBatch(batchPath):\n",
    "    with open(batchPath, 'rb') as file:\n",
    "        batchData = pickle.load(file, encoding='bytes')\n",
    "\n",
    "    images = batchData[b'data'].reshape(-1, 3, 32, 32)\n",
    "    labelKey = b'labels' if b'labels' in batchData else b'fine_labels'\n",
    "    labels = np.array(batchData[labelKey], dtype=np.int64)\n",
    "    return images, labels\n",
    "\n",
    "\n",
    "def resolveCifarDataDir(inputDir, outputDir):\n",
    "    directCandidates = [\n",
    "        inputDir / 'cifar-10-batches-py',\n",
    "        inputDir,\n",
    "    ]\n",
    "\n",
    "    for candidateDir in directCandidates:\n",
    "        if (candidateDir / 'batches.meta').exists():\n",
    "            return candidateDir\n",
    "\n",
    "    archiveCandidates = [\n",
    "        inputDir / 'cifar-10-python.tar.gz',\n",
    "        inputDir / 'cifar-10-batches-py.tar.gz',\n",
    "    ]\n",
    "    archivePath = next((path for path in archiveCandidates if path.exists()), None)\n",
    "\n",
    "    if archivePath is None:\n",
    "        raise FileNotFoundError('File CIFAR-10 tidak ditemukan dalam format folder maupun tar.gz.')\n",
    "\n",
    "    extractedRootDir = outputDir / 'cifar10-python-extracted'\n",
    "    extractedDataDir = extractedRootDir / 'cifar-10-batches-py'\n",
    "\n",
    "    if not extractedDataDir.exists():\n",
    "        extractedRootDir.mkdir(parents=True, exist_ok=True)\n",
    "        with tarfile.open(archivePath, 'r:gz') as tarFile:\n",
    "            tarFile.extractall(extractedRootDir)\n",
    "\n",
    "    return extractedDataDir\n",
    "\n",
    "\n",
    "def loadCifar10(dataDir):\n",
    "    trainImageList = []\n",
    "    trainLabelList = []\n",
    "\n",
    "    for batchIndex in range(1, 6):\n",
    "        batchImages, batchLabels = loadCifarBatch(dataDir / f'data_batch_{batchIndex}')\n",
    "        trainImageList.append(batchImages)\n",
    "        trainLabelList.append(batchLabels)\n",
    "\n",
    "    trainImages = np.concatenate(trainImageList, axis=0)\n",
    "    trainLabels = np.concatenate(trainLabelList, axis=0)\n",
    "    testImages, testLabels = loadCifarBatch(dataDir / 'test_batch')\n",
    "\n",
    "    with open(dataDir / 'batches.meta', 'rb') as file:\n",
    "        metaData = pickle.load(file, encoding='bytes')\n",
    "    classNames = [name.decode('utf-8') for name in metaData[b'label_names']]\n",
    "\n",
    "    return trainImages, trainLabels, testImages, testLabels, classNames\n"
   ]
