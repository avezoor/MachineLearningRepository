    "def packNamedArrays(namedArrays):\n",
    "    return np.concatenate([\n",
    "        namedArrays['w'].reshape(-1, 1),\n",
    "        namedArrays['b'].reshape(-1, 1),\n",
    "    ], axis=0).astype(np.float64)\n",
    "\n",
    "\n",
    "def unpackVectorToShapes(vector, parameters):\n",
    "    wSize = parameters['w'].size\n",
    "    return {\n",
    "        'w': vector[:wSize].reshape(parameters['w'].shape).astype(parameters['w'].dtype, copy=False),\n",
    "        'b': vector[wSize:].reshape(parameters['b'].shape).astype(parameters['b'].dtype, copy=False),\n",
    "    }\n",
    "\n",
    "\n",
    "def assignVectorToParameters(parameters, vector):\n",
    "    unpacked = unpackVectorToShapes(vector, parameters)\n",
    "    for name in parameters:\n",
    "        parameters[name][...] = unpacked[name]\n",
    "\n",
    "\n",
    "def prepareBatchState(parameters, batchContext):\n",
    "    if batchContext is None:\n",
    "        raise ValueError('batchContext diperlukan untuk optimizer orde-dua atau line search.')\n",
    "\n",
    "    xBatch = batchContext['xBatch'].astype(np.float64)\n",
    "    yBatch = batchContext['yBatch'].astype(np.float64)\n",
    "    numClasses = yBatch.shape[1]\n",
    "    xAugmented = np.concatenate([xBatch, np.ones((xBatch.shape[0], 1), dtype=np.float64)], axis=1)\n",
    "    decayMask = np.concatenate([np.ones((parameters['w'].size, 1), dtype=np.float64), np.zeros((parameters['b'].size, 1), dtype=np.float64)], axis=0)\n",
    "    return {\n",
    "        'xAugmented': xAugmented,\n",
    "        'yBatch': yBatch,\n",
    "        'weightDecay': float(batchContext.get('weightDecay', 0.0)),\n",
    "        'decayMask': decayMask,\n",
    "        'numClasses': numClasses,\n",
    "    }\n",
    "\n",
    "\n",
    "def splitThetaVector(thetaVector, batchState):\n",
    "    inputPlusBias = batchState['xAugmented'].shape[1]\n",
    "    numClasses = batchState['numClasses']\n",
    "    thetaMatrix = thetaVector.reshape(inputPlusBias, numClasses)\n",
    "    weightMatrix = thetaMatrix[:-1, :]\n",
    "    biasMatrix = thetaMatrix[-1:, :]\n",
    "    return weightMatrix, biasMatrix\n",
    "\n",
    "\n",
    "def computeBatchLossFromVector(thetaVector, batchState):\n",
    "    weightMatrix, biasMatrix = splitThetaVector(thetaVector, batchState)\n",
    "    logits = batchState['xAugmented'][:, :-1] @ weightMatrix + biasMatrix\n",
    "    probabilities = stableSoftmax(logits)\n",
    "    regularizationLoss = 0.5 * batchState['weightDecay'] * np.sum(weightMatrix ** 2)\n",
    "    return float(crossEntropyLoss(probabilities, batchState['yBatch']) + regularizationLoss)\n",
    "\n",
    "\n",
    "def computeBatchGradientFromVector(thetaVector, batchState):\n",
    "    weightMatrix, biasMatrix = splitThetaVector(thetaVector, batchState)\n",
    "    logits = batchState['xAugmented'][:, :-1] @ weightMatrix + biasMatrix\n",
    "    probabilities = stableSoftmax(logits)\n",
    "    batchSize = batchState['xAugmented'].shape[0]\n",
    "    delta = (probabilities - batchState['yBatch']) / batchSize\n",
    "    gradW = batchState['xAugmented'][:, :-1].T @ delta + batchState['weightDecay'] * weightMatrix\n",
    "    gradB = np.sum(delta, axis=0, keepdims=True)\n",
    "    return np.concatenate([gradW.reshape(-1, 1), gradB.reshape(-1, 1)], axis=0)\n",
    "\n",
    "\n",
    "def computeCurvatureDiagonal(thetaVector, batchState):\n",
    "    weightMatrix, biasMatrix = splitThetaVector(thetaVector, batchState)\n",
    "    logits = batchState['xAugmented'][:, :-1] @ weightMatrix + biasMatrix\n",
    "    probabilities = stableSoftmax(logits)\n",
    "    classCurvature = probabilities * (1.0 - probabilities)\n",
    "    xSquaredMean = np.mean(batchState['xAugmented'][:, :-1] ** 2, axis=0, keepdims=True).T\n",
    "    weightCurvature = xSquaredMean @ np.mean(classCurvature, axis=0, keepdims=True)\n",
    "    biasCurvature = np.mean(classCurvature, axis=0, keepdims=True)\n",
    "    weightCurvature += batchState['weightDecay']\n",
    "    curvatureVector = np.concatenate([weightCurvature.reshape(-1, 1), biasCurvature.reshape(-1, 1)], axis=0)\n",
    "    return np.maximum(curvatureVector, 1e-8)\n",
    "\n",
    "\n",
    "def softThreshold(values, threshold):\n",
    "    return np.sign(values) * np.maximum(np.abs(values) - threshold, 0.0)\n",
    "\n",
    "\n",
    "def performBacktrackingLineSearch(thetaVector, directionVector, gradientVector, batchState, initialStep=1.0, shrink=0.5, c1=1e-4, maxSteps=10):\n",
    "    stepSize = initialStep\n",
    "    baselineLoss = computeBatchLossFromVector(thetaVector, batchState)\n",
    "    directionalDerivative = float(np.sum(gradientVector * directionVector))\n",
    "\n",
    "    if directionalDerivative >= 0.0:\n",
    "        directionVector = -gradientVector\n",
    "        directionalDerivative = float(np.sum(gradientVector * directionVector))\n",
    "\n",
    "    for _ in range(maxSteps):\n",
    "        candidateTheta = thetaVector + stepSize * directionVector\n",
    "        candidateLoss = computeBatchLossFromVector(candidateTheta, batchState)\n",
    "        if candidateLoss <= baselineLoss + c1 * stepSize * directionalDerivative:\n",
    "            return stepSize, directionVector\n",
    "        stepSize *= shrink\n",
    "\n",
    "    return stepSize, directionVector\n"
   ]
