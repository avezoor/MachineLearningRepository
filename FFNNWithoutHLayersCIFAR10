    "def appendConfigIfMissing(configs, config):\n",
    "    existingNames = {existingConfig['name'] for existingConfig in configs}\n",
    "    if config['name'] not in existingNames:\n",
    "        configs.append(config)\n",
    "\n",
    "\n",
    "\n",
    "def buildExperimentConfigs(trainSize):\n",
    "    l2WeightDecay = 1e-4\n",
    "    stochasticEpochs = min(numEpochs, 24)\n",
    "    secondOrderEpochs = min(numEpochs, 20)\n",
    "    quasiNewtonEpochs = min(numEpochs, 20)\n",
    "\n",
    "    configs = [\n",
    "        {\n",
    "            'name': 'Batch GD',\n",
    "            'optimizerFactory': lambda: BatchGradientDescent(learningRate=0.12),\n",
    "            'batchSize': trainSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Mini-Batch GD',\n",
    "            'optimizerFactory': lambda: MiniBatchGradientDescent(learningRate=0.05),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Momentum',\n",
    "            'optimizerFactory': lambda: Momentum(learningRate=0.03, momentum=0.9),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'NAG',\n",
    "            'optimizerFactory': lambda: NAG(learningRate=0.03, momentum=0.9),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'RMSProp',\n",
    "            'optimizerFactory': lambda: RMSProp(learningRate=0.001, rho=0.99),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Adam',\n",
    "            'optimizerFactory': lambda: Adam(learningRate=0.001),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'AdamW',\n",
    "            'optimizerFactory': lambda: AdamW(learningRate=0.001, weightDecay=1e-4),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': 0.0,\n",
    "        },\n",
    "    ]\n",
    "\n",
    "    additionalConfigs = [\n",
    "        {\n",
    "            'name': 'SGD',\n",
    "            'optimizerFactory': lambda: StochasticGradientDescent(learningRate=0.01),\n",
    "            'batchSize': 1,\n",
    "            'numEpochs': stochasticEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'AdaGrad',\n",
    "            'optimizerFactory': lambda: AdaGrad(learningRate=0.03),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'AdaDelta',\n",
    "            'optimizerFactory': lambda: AdaDelta(rho=0.95),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'AMSGrad',\n",
    "            'optimizerFactory': lambda: AMSGrad(learningRate=0.001),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Nadam',\n",
    "            'optimizerFactory': lambda: Nadam(learningRate=0.001),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'AdaMax',\n",
    "            'optimizerFactory': lambda: AdaMax(learningRate=0.002),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Newton Method',\n",
    "            'optimizerFactory': lambda: NewtonMethod(learningRate=1.0, damping=1e-3),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': secondOrderEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Damped Newton',\n",
    "            'optimizerFactory': lambda: DampedNewton(learningRate=1.0, damping=1e-2),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': secondOrderEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Gauss-Newton',\n",
    "            'optimizerFactory': lambda: GaussNewton(learningRate=1.0, damping=1e-3),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': secondOrderEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Levenberg-Marquardt',\n",
    "            'optimizerFactory': lambda: LevenbergMarquardt(learningRate=1.0, damping=5e-2),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': secondOrderEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'BFGS',\n",
    "            'optimizerFactory': lambda: BFGS(learningRate=1.0),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': quasiNewtonEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'L-BFGS',\n",
    "            'optimizerFactory': lambda: LBFGS(learningRate=1.0, historySize=5),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': quasiNewtonEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Conjugate Gradient',\n",
    "            'optimizerFactory': lambda: ConjugateGradient(learningRate=1.0),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': quasiNewtonEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Natural Gradient',\n",
    "            'optimizerFactory': lambda: NaturalGradientDescent(learningRate=1.0, damping=1e-3),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': secondOrderEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Proximal Gradient',\n",
    "            'optimizerFactory': lambda: ProximalGradient(learningRate=0.005, l1Penalty=1e-6),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': 0.0,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Mirror Descent',\n",
    "            'optimizerFactory': lambda: MirrorDescent(learningRate=0.005),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': numEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "        {\n",
    "            'name': 'Coordinate Descent',\n",
    "            'optimizerFactory': lambda: CoordinateDescent(learningRate=0.03),\n",
    "            'batchSize': miniBatchSize,\n",
    "            'numEpochs': secondOrderEpochs,\n",
    "            'lossWeightDecay': l2WeightDecay,\n",
    "        },\n",
    "    ]\n",
    "\n",
    "    for config in additionalConfigs:\n",
    "        appendConfigIfMissing(configs, config)\n",
    "\n",
    "    return configs\n",
    "\n",
    "\n",
    "experimentConfigs = buildExperimentConfigs(len(xTrain))\n",
    "assert len(experimentConfigs) == 24, f\"Jumlah optimizer harus 24, saat ini {len(experimentConfigs)}\"\n",
    "assert len({config['name'] for config in experimentConfigs}) == 24, 'Nama optimizer harus unik'\n",
    "pd.DataFrame(\n",
    "    [\n",
    "        {\n",
    "            'Optimizer': config['name'],\n",
    "            'Ukuran Batch': config['batchSize'],\n",
    "            'Jumlah Epoch': config['numEpochs'],\n",
    "            'Peluruhan Bobot pada Loss': config['lossWeightDecay'],\n",
    "        }\n",
    "        for config in experimentConfigs\n",
    "    ]\n",
    ")\n"
